{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "instructions": ["~/.config/opencode/system-prompt.md"],
  "default_agent": "build",
  "agent": {
    "coder": {
      "mode": "primary",
      "prompt": "~/.config/opencode/coder-prompt.md",
    },
    "maker": {
      "mode": "subagent",
      "prompt": "~/.config/opencode/maker-prompt.md",
    },
  },
}
